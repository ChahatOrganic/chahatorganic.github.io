<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Chahat Organic | Pure • Honest • Farmer Sourced</title>

<meta name="description" content="Chahat Organic offers premium organic spices sourced directly from Indian farmers. Pure, chemical-free and honest food.">
<meta name="keywords" content="Chahat Organic, organic spices India, organic turmeric, chemical free food, farmer sourced">

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
:root{
  --green:#0f3d2e;
  --green2:#1b5e20;
  --gold:#f4d03f;
  --orange:#e67e22;
  --light:#f6f8f6;
  --dark:#111;
}
*{box-sizing:border-box}
body{
  margin:0;
  font-family:Poppins,Arial,sans-serif;
  background:var(--light);
  color:#333;
  transition:.3s;
}

/* DARK MODE */
body.dark{background:#121212;color:#e0e0e0}
body.dark section,
body.dark .product,
body.dark .modal-box,
body.dark .ask,
body.dark .vision{
  background:#1e1e1e;
  color:#ddd;
}
body.dark header{background:#0b2a20}
body.dark footer{background:#000}

/* HEADER */
header{
  position:sticky;
  top:0;
  z-index:999;
  background:rgba(15,61,46,.95);
  color:#fff;
  text-align:center;
  padding:22px 16px;
}
header h1{
  margin:0;
  font-family:"Playfair Display",serif;
  font-size:38px;
}
.hindi{color:var(--gold)}
.tagline{font-size:14px;opacity:.9}
.toggle{
  position:absolute;
  right:16px;
  top:16px;
  border:1px solid #ccc;
  background:none;
  color:#fff;
  padding:6px 14px;
  border-radius:20px;
  cursor:pointer;
}

/* ===== HERO SLIDER ===== */
.hero{
  min-height:95vh;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  color:#fff;
  position:relative;
  background-size:cover;
  background-position:center;
  transition:background-image 1s ease-in-out;
  overflow:hidden;
}

/* CINEMATIC ZOOM */
.hero.zoom{
  animation:zoomEffect 7s ease-in-out forwards;
}
@keyframes zoomEffect{
  from{transform:scale(1)}
  to{transform:scale(1.08)}
}

.hero::before{
  content:"";
  position:absolute;
  inset:0;
  background:rgba(0,0,0,.65);
  z-index:1;
}

.hero-content{
  position:relative;
  z-index:2;
  padding:0 20px;
}

.hero h2{
  font-size:52px;
  font-family:"Playfair Display",serif;
}
.hero p{
  font-size:20px;
  max-width:850px;
  margin:auto;
}

/* DOTS */
.hero-dots{
  margin-top:30px;
  display:flex;
  justify-content:center;
  gap:10px;
}
.hero-dots span{
  width:10px;
  height:10px;
  border-radius:50%;
  background:rgba(255,255,255,.4);
  cursor:pointer;
  transition:.3s;
}
.hero-dots span.active{
  background:#f4d03f;
  transform:scale(1.5);
}

/* SECTIONS */
section{padding:90px 8%;background:#fff}
h2{text-align:center;color:var(--green)}
.lead{text-align:center;max-width:900px;margin:20px auto 50px}

/* PRODUCTS */
.products{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:30px;
}
.product{
  background:#fff;
  border-radius:22px;
  padding:20px;
  box-shadow:0 10px 28px rgba(0,0,0,.12);
  cursor:pointer;
  text-align:center;
  transition:.3s;
}
.product:hover{transform:translateY(-6px)}
.product img{
  width:100%;
  height:210px;
  object-fit:cover;
  border-radius:16px;
}
.product h3{color:var(--green2)}
.badge{
  background:#fdecea;
  color:#c0392b;
  padding:6px 16px;
  border-radius:999px;
  font-size:13px;
}

/* STORY */
.story{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:40px;
  align-items:center;
}
.story img{width:100%;border-radius:22px}
.story p{font-size:17px;line-height:1.9}

/* ASK */
.ask{text-align:center;background:#f8fbf8}
.ask form{max-width:520px;margin:auto}
.ask input,.ask textarea{
  width:100%;
  padding:12px;
  margin:10px 0;
  border:1px solid #ccc;
}
.ask button{
  padding:12px 26px;
  background:var(--green2);
  color:#fff;
  border:none;
  cursor:pointer;
}

/* VISION */
.vision{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:40px;
  align-items:center;
}
.vision img{width:100%;border-radius:22px}
.vision h3{color:var(--orange);font-size:28px}

/* MODAL */
.modal{
  display:none;
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.75);
  justify-content:center;
  align-items:center;
  z-index:2000;
}
.modal-box{
  background:#fff;
  padding:30px;
  border-radius:22px;
  max-width:860px;
  width:92%;
}
.back{
  cursor:pointer;
  color:var(--green2);
  font-weight:600;
  margin-bottom:10px;
  display:inline-block;
}
.qty{display:flex;gap:12px;align-items:center;margin:12px 0}
.qty button{
  background:var(--green2);
  color:#fff;
  border:none;
  width:36px;
  height:36px;
  border-radius:50%;
}
.buy{
  width:100%;
  padding:14px;
  background:var(--green2);
  color:#fff;
  border:none;
  border-radius:30px;
  margin-top:14px;
}

/* FOOTER */
footer{
  background:var(--dark);
  color:#eee;
  text-align:center;
  padding:60px 16px;
}

/* WHATSAPP */
.whatsapp{
  position:fixed;
  bottom:20px;
  right:20px;
  background:#25d366;
  color:#fff;
  padding:14px 18px;
  border-radius:50px;
  text-decoration:none;
  font-weight:600;
}

@media(max-width:900px){
  .story,.vision{grid-template-columns:1fr}
}
</style>
</head>

<body>

<header>
<h1>Chahat Organic</h1>
<div class="hindi">🌿 अपनों के लिए चाह</div>
<div class="tagline">Pure • Natural • Farmer Sourced</div>
<button class="toggle" onclick="toggleDark()">🌙 Dark</button>
</header>

<!-- HERO -->
<div class="hero" id="hero">
  <div class="hero-content">
    <h2>Pure Organic From Farmers<br>To Your Family</h2>
    <p>Carefully sourced organic spices grown with honesty and delivered with care.</p>
    <div class="hero-dots" id="heroDots"></div>
  </div>
</div>

<section>
<h2>Our Organic Products</h2>
<p class="lead">Premium everyday essentials crafted with purity and transparency.</p>
<div class="products" id="productGrid"></div>
</section>

<!-- ARTICLES -->
<section class="articles" style="background:#f9faf9">
<h2>Our Articles</h2>
<p class="lead">Explore our thoughtfully written articles to understand organic living.</p>
<div class="products">
<div class="product" onclick="location.href='articles.html?post=turmeric'">
<img src="16_article-header-organic-turmeric.jpg">
<h3>Benefits of Organic Turmeric</h3>
<span class="badge">READ ARTICLE</span>
</div>
<div class="product" onclick="location.href='articles.html?post=tea'">
<img src="17_article-header-organic-tea.jpg">
<h3>Why Choose Organic Tea?</h3>
<span class="badge">READ ARTICLE</span>
</div>
<div class="product" onclick="location.href='articles.html?post=chemical-free'">
<img src="18_article-header-chemical-free-food.jpg">
<h3>Chemical-Free Food</h3>
<span class="badge">READ ARTICLE</span>
</div>
<div class="product" onclick="location.href='articles.html?post=organic-spices'">
<img src="20_health-benefits-organic-spices.jpg">
<h3>Organic Spices Benefits</h3>
<span class="badge">READ ARTICLE</span>
</div>
</div>
</section>

<footer>
© 2026 Chahat Organic • Honest Food • Honest Living<br><br>
<b>Founder & Managed by Shubham Mishra</b>
</footer>

<script>
function toggleDark(){
 document.body.classList.toggle("dark");
 localStorage.setItem("dark",document.body.classList.contains("dark"));
}
if(localStorage.getItem("dark")==="true")document.body.classList.add("dark");

/* HERO SLIDER JS – 7 SECONDS */
const heroImages=[
 "25_firstpage.png",
 "01_Hero_Spice_Flat_Lay.png",
 "02_Hero_Farmer_Harvest.png",
 "03_Hero_Oxen_Plough.png",
 "04_Hero_Spice_Drying.png",
 "05_Hero_Spice_Market.png",
 "06_Hero_Turmeric_Macro.png",
 "07_Hero_Product_Packaging.png",
 "08_Hero_Masala_Making.png",
 "09_Hero_Export_Ready.png",
 "10_Hero_Family_Farmers.png"
];

const hero=document.getElementById("hero");
const dotsContainer=document.getElementById("heroDots");
let index=0,startX=0;

heroImages.forEach((_,i)=>{
 const dot=document.createElement("span");
 dot.onclick=()=>setHeroImage(i);
 dotsContainer.appendChild(dot);
});
const dots=document.querySelectorAll(".hero-dots span");

function setHeroImage(i){
 index=i;
 hero.classList.remove("zoom");
 void hero.offsetWidth;
 hero.classList.add("zoom");
 hero.style.backgroundImage=
 `linear-gradient(rgba(0,0,0,.65),rgba(0,0,0,.65)),url('${heroImages[i]}')`;
 dots.forEach(d=>d.classList.remove("active"));
 dots[i].classList.add("active");
}

setHeroImage(0);
setInterval(()=>setHeroImage((index+1)%heroImages.length),7000);

/* SWIPE */
hero.addEventListener("touchstart",e=>startX=e.touches[0].clientX);
hero.addEventListener("touchend",e=>{
 let endX=e.changedTouches[0].clientX;
 if(startX-endX>50) setHeroImage((index+1)%heroImages.length);
 else if(endX-startX>50) setHeroImage((index-1+heroImages.length)%heroImages.length);
});
</script>

</body>
</html>
