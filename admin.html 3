<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<title>Chahat Organic | Admin Dashboard</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0"><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"><style>
body{font-family:Arial,Helvetica,sans-serif;margin:0;background:#f4f7f4;}
header{background:#1b5e20;color:white;padding:20px;text-align:center;}
nav{background:#2e7d32;padding:10px;text-align:center;}
nav a{color:white;margin:10px;text-decoration:none;font-weight:bold;}
.auth{text-align:right;padding:10px 20px;}
button{padding:8px 15px;border:none;background:#1b5e20;color:white;cursor:pointer;border-radius:5px;margin:5px;}
.container{max-width:900px;margin:auto;padding:20px;}
input,textarea,select{width:100%;padding:10px;margin-top:10px;border-radius:8px;border:1px solid #ccc;}
.category-bar{padding:10px;text-align:center;background:#e8f5e9;}
.category-bar span{margin:10px;font-weight:bold;}
.editor{border:1px solid #ccc;padding:15px;min-height:200px;border-radius:10px;background:white;margin-top:10px;}
.toolbar{margin-top:10px;display:flex;flex-wrap:wrap;gap:6px;justify-content:center;}
.toolbar button,.toolbar select{padding:8px;border-radius:6px;border:1px solid #ccc;cursor:pointer;}
.actions{text-align:center;margin-top:15px;}
.previewBox{background:white;padding:20px;border-radius:10px;margin-top:20px;display:none;}
.articleList{background:white;margin-top:25px;padding:20px;border-radius:10px;}
.articleItem{border-bottom:1px solid #eee;padding:10px 0;}
.likeBtn{background:#ff4081;}
.shareBox i{font-size:20px;margin:10px;cursor:pointer;}
</style></head><body><header>
<h1>🌿 Chahat Organic Admin Dashboard</h1>
</header><nav>
<a href="https://chahatorganic.github.io/">Home</a>
<a href="https://chahatorganic.github.io/articles.html">Articles</a>
<a href="https://chahatorganic.github.io/about.html">About</a>
<a href="mailto:chahatorganic@gmail.com">Email</a>
<a href="https://instagram.com/chahatorganic" target="_blank">Instagram</a>
</nav><div class="auth">
<button onclick="login()">Login</button>
<button onclick="logout()">Logout</button>
</div><div class="container"><input id="title" placeholder="Article Title">
<textarea id="description" placeholder="Short Description"></textarea>
<input id="image" placeholder="Featured Image URL"><div class="category-bar">
<span>Health</span>
<span>Organic Food</span>
<span>Ayurveda</span>
<span>Recipes</span>
</div><select id="category">
<option>Health</option>
<option>Organic Food</option>
<option>Ayurveda</option>
<option>Recipes</option>
</select><div class="toolbar">
<button onclick="format('bold')"><b>B</b></button>
<button onclick="format('italic')"><i>I</i></button>
<button onclick="format('insertUnorderedList')">•</button>
<button onclick="addImage()">🖼</button>
<select onchange="changeFont(this.value)">
<option>Font</option>
<option>Arial</option>
<option>Georgia</option>
<option>Courier</option>
</select>
<input type="color" onchange="changeColor(this.value)">
</div><div id="editor" class="editor" contenteditable="true">
Start writing your article...
</div><div class="actions">
<button onclick="aiWriter()">🤖 AI Write Article</button>
<button onclick="preview()">👁 Preview</button>
<button onclick="publish()">🚀 Publish Article</button>
</div><div id="previewBox" class="previewBox"></div><div class="articleList">
<h3>📚 Published Articles</h3>
<div id="articlesList"></div>
</div></div><script>
function format(cmd){document.execCommand(cmd);}
function changeColor(c){document.execCommand("foreColor",false,c);}
function changeFont(f){document.execCommand("fontName",false,f);}

function addImage(){
let url=prompt("Paste Image URL");
if(url){document.execCommand("insertHTML",false,`<img src="${url}" style="max-width:100%;border-radius:10px">`);}
}

function aiWriter(){
let topic=prompt("Enter topic");
editor.innerHTML=`<h2>${topic}</h2><p>${topic} is important for organic life.</p>`;
}

function preview(){
previewBox.style.display="block";
previewBox.innerHTML=`
<h2>${title.value}</h2>
<img src="${image.value}" style="width:100%;border-radius:10px">
<p>${description.value}</p>
${editor.innerHTML}
<button class="likeBtn">❤️ Like</button>
<div class="shareBox">
<i class="fab fa-whatsapp" onclick="share('whatsapp')"></i>
<i class="fab fa-facebook" onclick="share('facebook')"></i>
<i class="fa fa-share" onclick="share('other')"></i>
</div>`;
}

function publish(){
let div=document.createElement("div");
div.className="articleItem";
div.innerHTML=`<b>${title.value}</b><br><button onclick="this.parentElement.remove()">Delete</button>`;
articlesList.appendChild(div);
alert("Published");
}

function share(type){
let url=encodeURIComponent(location.href);
if(type==='whatsapp') window.open(`https://wa.me/?text=${url}`);
if(type==='facebook') window.open(`https://www.facebook.com/sharer/sharer.php?u=${url}`);
if(type==='other') navigator.share({url:location.href});
}

function login(){alert('Login logic add karo Firebase wala');}
function logout(){alert('Logout');}
</script></body>
</html>
